key "Alt+t" xterm
key "Alt+b" firefox
key "Alt+m" rofi -show drun
key "Alt+q" /bin/sh -c "scrot -u -e 'xclip -selection clipboard -t image/png -i $f' && yad --center --text='Active window screenshot copied to clipboard' --timeout=3"
key "Alt+p" ~/Cpp/cpp_xtemplate/cpp_xtemplate

key "XF86AudioLowerVolume"  amixer sset Master 5%-
key "XF86AudioRaiseVolume"  amixer sset Master 5%+
key "XF86AudioMute"         amixer sset Master toggle
key "XF86HomePage"          xdg-open about:blank
key "XF86Search"            xdg-open https://www.google.com
key "XF86Eject"             eject
